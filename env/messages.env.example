# Copy this file to messages.env and customize your Telegram templates.
# messages.env is gitignored.
#
# Optional: {cnt} → trade ID as number emoji (e.g. 1️⃣4️⃣).
# Incremented by shortcuts marked “Increment trade ID” in Settings.

ORDER_MESSAGE="📝 *ORDER SUBMITTED*

*Symbol:* `{symbol}`
*Exchange:* `{exchange}`
*Action:* `{action}`
*Size:* `{percentage}` of full size
*Type:* `{order_type}`
*Price:* `{limit_price}`
*Status:* `{status}`"
ORDER_OPTION_MESSAGE="📝 *OPTION ORDER SUBMITTED*

*Underlying:* `{symbol}`
*Contract:* `{contract_description}`
*Action:* `{action}`
*Size:* `{percentage}` of full size
*Type:* `{order_type}`
*Price:* `{limit_price}`
*Status:* `{status}`"
ORDER_FUTURE_MESSAGE="📝 *FUTURES ORDER SUBMITTED*

*Symbol:* `{symbol}`
*Contract:* `{contract_description}`
*Expiry:* `{expiry}`
*Exchange:* `{exchange}`
*Action:* `{action}`
*Size:* `{percentage}` of full size
*Type:* `{order_type}`
*Price:* `{limit_price}`
*Status:* `{status}`"
TRADE_MESSAGE="✅ *ORDER FILLED*

*Symbol:* `{symbol}`
*Exchange:* `{exchange}`
*Action:* `{side}`
*Size:* `{percentage}` of full size
*Price:* `${price}`
*Commission:* `${commission}`
*Time:* `{time}`
*Account:* `{account}`"
OPTION_MESSAGE="✅ *OPTION ORDER FILLED*

*Underlying:* `{symbol}`
*Contract:* `{contract_description}`
*Type:* `{option_type}`
*Strike:* `${strike}`
*Expiry:* `{expiry}`
*Action:* `{side}`
*Size:* `{percentage}` of full size
*Price:* `${price}`
*Commission:* `${commission}`
*Time:* `{time}`
*Account:* `{account}`"
FUTURE_MESSAGE="✅ *FUTURES ORDER FILLED*

*Symbol:* `{symbol}`
*Contract:* `{contract_description}`
*Expiry:* `{expiry}`
*Exchange:* `{exchange}`
*Action:* `{side}`
*Size:* `{percentage}` of full size
*Price:* `{price}`
*Commission:* `${commission}`
*Time:* `{time}`
*Account:* `{account}`"
SUMMARY_MESSAGE="📊 *SUMMARY*

*Trades taken:* `{trades}`
🟢 *Green:* `{green}`
🔴 *Red:* `{red}`"
LONG_TERM_SUMMARY_MESSAGE="📊 *LONG-TERM SUMMARY*

*Trades taken:* `{trades}`
🟢 *Green:* `{green}`
🔴 *Red:* `{red}`"
CONNECTED_MESSAGE="✅ Connected to IBKR. Ready for trades."
CLOSED_MESSAGE="📊 Market closed. Trade monitor stopping."
